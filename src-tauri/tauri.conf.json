{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cdx-swap",
  "version": "0.1.3",
  "identifier": "dev.yhyunmin.cdx-swap",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "cdx-swap",
        "width": 420,
        "height": 560,
        "resizable": false,
        "decorations": false,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Codex profile usage tray app",
    "longDescription": "Windows-first tray app for viewing Codex usage and safely restarting Codex Desktop."
  }
}
