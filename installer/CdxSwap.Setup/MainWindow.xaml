<Window
    x:Class="CdxSwap.Setup.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="cdx-swap Setup"
    Width="548"
    Height="500"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    Background="#F8F8FA"
    FontFamily="Segoe UI"
    Foreground="{StaticResource TextBrush}"
    Icon="Assets/icon.ico">
    <Border
        Background="#F8F8FA"
        BorderBrush="#E3E3EA"
        BorderThickness="1"
        CornerRadius="18">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="64" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid x:Name="DragRegion" Grid.Column="0" MouseLeftButtonDown="DragRegion_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10" Fill="#FF5F57" Margin="0,0,8,0" />
                        <Ellipse Width="10" Height="10" Fill="#FFBD2E" Margin="0,0,8,0" />
                        <Ellipse Width="10" Height="10" Fill="#28C840" />
                    </StackPanel>
                </Grid>
                <Button
                    x:Name="CloseButton"
                    Grid.Column="1"
                    Width="36"
                    Height="36"
                    Padding="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Click="CloseButton_Click"
                    Content="X" />
            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,18">
                    <Border
                        Width="84"
                        Height="84"
                        CornerRadius="24"
                        Background="{StaticResource AccentBrush}"
                        Margin="0,0,0,10">
                        <Image
                            Width="64"
                            Height="64"
                            Source="Assets/app-icon.png"
                            Stretch="Uniform" />
                    </Border>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="26"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextBrush}"
                        Text="cdx-swap"
                        Margin="0,0,0,4" />
                    <TextBlock
                        x:Name="VersionText"
                        HorizontalAlignment="Center"
                        FontSize="13"
                        Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>

                <Border
                    Grid.Row="1"
                    Padding="22"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                    <StackPanel>
                        <TextBlock
                            x:Name="TitleText"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextBrush}" />
                        <TextBlock
                            x:Name="DescriptionText"
                            FontSize="14"
                            Foreground="{StaticResource MutedTextBrush}"
                            TextWrapping="Wrap"
                            Margin="0,8,0,16" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Text="*"
                                Foreground="{StaticResource AccentBrush}"
                                FontSize="18"
                                Margin="0,0,12,0" />
                            <TextBlock
                                Grid.Column="1"
                                FontSize="13"
                                Foreground="{StaticResource MutedTextBrush}"
                                Text="Per-user Windows Installer payload. No network is required after download."
                                TextWrapping="Wrap" />
                        </Grid>
                        <CheckBox
                            x:Name="LaunchAfterInstallToggle"
                            Content="Launch after install"
                            IsChecked="True"
                            Margin="0,0,0,16" />
                        <ProgressBar
                            x:Name="InstallProgress"
                            Height="8"
                            IsIndeterminate="True"
                            Visibility="Collapsed"
                            Margin="0,0,0,14" />
                        <TextBlock
                            x:Name="StatusText"
                            FontSize="14"
                            Foreground="{StaticResource TextBrush}"
                            TextWrapping="Wrap"
                            Margin="0,0,0,8" />
                        <TextBlock
                            x:Name="LogPathText"
                            FontFamily="Consolas"
                            FontSize="12"
                            Foreground="{StaticResource MutedTextBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" VerticalAlignment="Bottom">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="OpenLogButton"
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    Click="OpenLogButton_Click"
                    Content="Open log"
                    Visibility="Collapsed" />
                <Button
                    x:Name="RetryButton"
                    Grid.Column="1"
                    Margin="0,0,10,0"
                    Click="RetryButton_Click"
                    Content="Retry"
                    Visibility="Collapsed" />
                <Button
                    x:Name="LaunchButton"
                    Grid.Column="2"
                    Margin="0,0,10,0"
                    Click="LaunchButton_Click"
                    Content="Launch cdx-swap"
                    Visibility="Collapsed" />
                <Button
                    x:Name="InstallButton"
                    Grid.Column="3"
                    Click="InstallButton_Click"
                    Content="Install"
                    Background="{StaticResource AccentBrush}"
                    BorderBrush="{StaticResource AccentBrush}"
                    Foreground="White" />
            </Grid>
        </Grid>
    </Border>
</Window>
