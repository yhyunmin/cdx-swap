<Window
    x:Class="CdxSwap.Setup.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid x:Name="Root" Background="#FFF8F8FA" Padding="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
            <RowDefinition Height="64" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid x:Name="DragRegion" Grid.Column="0">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#FFFF5F57" />
                    <Ellipse Width="10" Height="10" Fill="#FFFFBD2E" />
                    <Ellipse Width="10" Height="10" Fill="#FF28C840" />
                </StackPanel>
            </Grid>
            <Button
                x:Name="CloseButton"
                Grid.Column="1"
                Width="36"
                Height="36"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Click="CloseButton_Click">
                <FontIcon FontSize="12" Glyph="&#xE8BB;" />
            </Button>
        </Grid>

        <Grid Grid.Row="1" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="10">
                <Border
                    Width="84"
                    Height="84"
                    CornerRadius="24"
                    Background="{StaticResource AccentBrush}">
                    <Image
                        x:Name="AppIconImage"
                        Width="64"
                        Height="64"
                        Stretch="Uniform" />
                </Border>
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="26"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextBrush}"
                    Text="cdx-swap" />
                <TextBlock
                    x:Name="VersionText"
                    HorizontalAlignment="Center"
                    FontSize="13"
                    Foreground="{StaticResource MutedTextBrush}" />
            </StackPanel>

            <Border
                Grid.Row="1"
                Padding="22"
                Background="{StaticResource PanelBrush}"
                BorderBrush="#FFE8E8EC"
                BorderThickness="1"
                CornerRadius="18">
                <StackPanel Spacing="16">
                    <TextBlock
                        x:Name="TitleText"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextBrush}" />
                    <TextBlock
                        x:Name="DescriptionText"
                        FontSize="14"
                        Foreground="{StaticResource MutedTextBrush}"
                        TextWrapping="Wrap" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            Grid.Column="0"
                            FontSize="18"
                            Foreground="{StaticResource AccentBrush}"
                            Glyph="&#xE896;" />
                        <TextBlock
                            Grid.Column="1"
                            FontSize="13"
                            Foreground="{StaticResource MutedTextBrush}"
                            Text="Per-user Windows Installer payload. No network is required after download."
                            TextWrapping="Wrap" />
                    </Grid>
                    <ToggleSwitch
                        x:Name="LaunchAfterInstallToggle"
                        Header="Launch after install"
                        IsOn="True" />
                    <ProgressRing
                        x:Name="InstallProgress"
                        Width="36"
                        Height="36"
                        HorizontalAlignment="Left"
                        IsActive="False"
                        Visibility="Collapsed" />
                    <TextBlock
                        x:Name="StatusText"
                        FontSize="14"
                        Foreground="{StaticResource TextBrush}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="LogPathText"
                        FontFamily="Consolas"
                        FontSize="12"
                        Foreground="{StaticResource MutedTextBrush}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="12" VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="OpenLogButton"
                Grid.Column="0"
                HorizontalAlignment="Left"
                Click="OpenLogButton_Click"
                Content="Open log"
                Visibility="Collapsed" />
            <Button
                x:Name="RetryButton"
                Grid.Column="1"
                Click="RetryButton_Click"
                Content="Retry"
                Visibility="Collapsed" />
            <Button
                x:Name="LaunchButton"
                Grid.Column="2"
                Click="LaunchButton_Click"
                Content="Launch cdx-swap"
                Visibility="Collapsed" />
            <Button
                x:Name="InstallButton"
                Grid.Column="3"
                Click="InstallButton_Click"
                Content="Install" />
        </Grid>
    </Grid>
</Window>
